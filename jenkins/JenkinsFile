pipeline {
    // Define que el pipeline puede ejecutarse en cualquier agente (nodo) disponible en Jenkins
    agent any
    
    stages {
        // Stage contenedor principal que agrupa las ejecuciones en paralelo
        stage('Unit Test') {
            parallel {
                
                // ==========================================
                //  SUB-STAGE: PRUEBAS UNITARIAS DEL BACKEND
                // ==========================================
                stage('Unit Test Backend') {
                    agent {
                        // Levanta un contenedor Docker específico para el entorno de Go
                        docker {
                            image 'snakee/golang-junit:1.21'
                            reuseNode true // Reutiliza el espacio de trabajo del nodo actual
                            // Solución al error de permisos: Redirige la caché de Go a la carpeta /tmp
                            args '-e GOCACHE=/tmp/go-cache -e GOPATH=/tmp/go-path'
                        }
                    }
                    steps {
                        // Cambia el directorio de ejecución a la carpeta del backend
                        dir ('bugtracker-backend') {
                            sh '''
                                # Ejecuta los tests de Go, calcula cobertura atómica y canaliza la salida para generar el XML de JUnit
                                go test -v -coverprofile=coverage.out -covermode=atomic ./... 2>&1 | go-junit-report > report.xml
                                
                                # Convierte el reporte de cobertura binario (.out) en un archivo web HTML legible
                                go tool cover -html=coverage.out -o coverage.html 

                                # Crea de forma segura la carpeta 'reports' e introduce el HTML generado
                                mkdir -p reports
                                mv coverage.html reports/
                            '''
                        }
                    }
                    // Acciones post-ejecución del Backend
                    post {
                        always {
                            // Registra y grafica los resultados de las pruebas en la interfaz de Jenkins
                            junit 'bugtracker-backend/report.xml'
                            
                            // Publica el reporte HTML de cobertura en el panel lateral de Jenkins
                            publishHTML (target: [
                                allowMissing: false,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'bugtracker-backend/reports',
                                reportFiles: 'coverage.html',
                                reportName: 'Backend Coverage Report'
                              ])
                        }
                    }  
                } // Fin del Sub-Stage Backend

                // ==========================================
                //  SUB-STAGE: PRUEBAS UNITARIAS DEL FRONTEND
                // ==========================================
                stage('Unit Test FrontEnd') {
                    agent {
                        // Levanta un contenedor Docker con Node.js en su versión ligera
                        docker {
                            image 'node:20-alpine'
                            reuseNode true
                        }
                    }
                    steps {
                        // Cambia el directorio de ejecución a la carpeta del frontend
                        dir ('bugtracker-frontend') {
                            sh '''
                                # Instalación limpia y exacta de las dependencias usando el package-lock.json
                                npm ci 
                                
                                # MODIFICACIÓN: Forzamos a Jest a volcar el reporte HTML en una carpeta específica llamada 'html-report'
                                npm test -- --coverageDirectory="html-report"
                            '''
                        }
                    }
                    // Acciones post-ejecución del Frontend
                    post {
                        always {
                            // Registra los resultados de las pruebas del frontend en Jenkins
                            junit 'bugtracker-frontend/test-results.xml'
                            
                            // Publica la cobertura de Jest apuntando a la nueva carpeta garantizada
                            publishHTML (target: [
                                allowMissing: false,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                // MODIFICACIÓN: Apuntamos a la carpeta que forzamos arriba
                                reportDir: 'bugtracker-frontend/html-report',
                                reportFiles: 'index.html',
                                reportName: 'Frontend Coverage Report'
                            ])
                        }  
                    }
                } // Fin del Sub-Stage Frontend
                
            }
        } // Fin del Stage Unit Test
    }
    
    // Acciones globales que se ejecutan al finalizar COMPLETAMENTE todo el pipeline
    post {
        always {
            // Borra todo el espacio de trabajo en el servidor para no dejar basura ni saturar el disco
            cleanWs()
        }
    }
}